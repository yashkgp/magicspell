# MagicSpell API Configuration
# Set one of the following API keys:

# OpenAI API key (uses gpt-4o-mini by default)
# OPENAI_API_KEY=sk-...

# Anthropic API key (uses claude-sonnet-4-20250514 by default)
# ANTHROPIC_API_KEY=sk-ant-...

# Slack Integration (required for the /proofread slash command bot)
# Create a Slack app at https://api.slack.com/apps with these scopes:
#   Bot Token Scopes: commands, channels:history, chat:write
#   Enable Socket Mode and generate an App-Level Token with connections:write
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...
